/**************************function********************************* */

async function getAnswer(message:any){
  console.log("getAnswer进来了-----------------------")
  

  const res= await fetch(`http://127.0.0.1:9000/ragkb/agent/chatByInput`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",  
    },
    body: message

    })
    const data = await res.json();

  chrome.tabs.query({ active: true, currentWindow: true }, (tabs) => {
    if (tabs[0].id) {

        chrome.tabs.sendMessage(tabs[0].id, {type:"pdd_receive", message: data,abc:"111" }, (response) => {
            console.log("Response from content:", response);
        });
    }

  });
  console.log("backgroud_resp:-------",response)

  return response.body
  // const response =  fetch(`http://127.0.0.1:9000/ragkb/agent/chatByInput`, {

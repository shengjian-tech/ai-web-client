// Listen for PDD page messages
function logEvent(event: Event): void {
  console.log(`Event triggered: ${event.type}`);
}

async function detectChatList(elementMsg: HTMLElement): Promise<void> {
  const elements = document.getElementsByClassName('all-chat-list group-chat');
  console.log("All chat lists:", elements);

  if (elements.length > 0) {
    const element = elements[0];
    const chatItems = element.querySelectorAll(".chat-item");
    console.log("Chat users:", chatItems);
    // 使用扩展运算符转换为数组
  
    for (const item of chatItems) {
      const i = item.querySelector("i");
      if (i) {
        const display = window.getComputedStyle(i).display;
        if (display !== "none") {
          const chatUser = item.getElementsByClassName("chat-item-box transition")[0];

          const userIdStr = chatUser.getAttribute("data-random");
          const userId = userIdStr?.split("-")[0];
            
          //模拟点击事件 down move up缺一不可
          const mousedownEvent = new MouseEvent('mousedown', {
            bubbles: true,
            cancelable: true,
            view: window,
            button: 0,
          });

          chatUser.dispatchEvent(mousedownEvent);

          const moveEvent = new MouseEvent('mousemove', {
            bubbles: true,
            cancelable: true,
            view: window,
          });
          chatUser.dispatchEvent(moveEvent);

          const upEvent = new MouseEvent('mouseup', {
            bubbles: true,
            cancelable: true,
            view: window,
          });
          chatUser.dispatchEvent(upEvent);

          await sleep(1000);
          await getMsgList(elementMsg, userId as string);
        }
      }
    }
  }
}

async function waitForElement(selector: string, callback: (element: HTMLElement) => void): Promise<void> {


  observer.observe(document.body, config);

   interval_Pdd = setInterval(async () => {
    console.log("监听DOM react项目...");
    const element = document.querySelector(selector) as HTMLElement;
    if (element) {
      if (stopFlag) {
        console.log("正在执行锁未释放...");
        return;
      }

      await detectChatList(element);
      callback(element);
    }
  }, 3000); // Check every 3 seconds
}

async function getMsgList(element: HTMLElement, userId: string): Promise<void> {

    let buyer =null;
  const lastLi = element.lastElementChild as HTMLElement;
  const isVioAl = lastLi?.getElementsByClassName("content-box");
  if (isVioAl?.length > 0) {
    const textContent = isVioAl[0]?.textContent;
    console.log("textContent:---",textContent)
    // if(textContent=="您接待过此消费者，为避免插嘴、抢答，机器人已暂停接待，>>点此【立即恢复接待】<<"){
    //    const bun= isVioAl[0].getElementsByClassName("btn")[0] as HTMLButtonElement;
    //    bun.onclick=()=>{
    //     console.log("点击了立即恢复接待-----")
    //    }

    
    // }

      const liElements = Array.from(element.children);
       buyer = liElements.slice(-2)[0] as HTMLElement;
    
  } else {
     buyer = lastLi.querySelector(".buyer-item")as HTMLElement ;
  }

  if (buyer) {
    stopFlag = true;
    const message = buyer.querySelector(".msg-content-box")?.textContent;
    const sendButton = document.getElementsByClassName("send-btn")[0] as HTMLButtonElement;

    if (sendButton) {
      const param = { message, roomId: `${userId}${pddCustomerInfo.mallId}` };
      chrome.runtime.sendMessage({ type: "pdd_send", message: JSON.stringify(param) }, () => {
        console.log("User message sent.");
      });
    }
  }
}


//************************************主入口 */

//避免刷新页面丢失状态
chrome.storage.local.get(['pddIsStart'],(value:any)=>{
  if(value==true){
    waitForElement('.msg-list', (element) => {
      console.log("DOM is loading...");
    });
  }else{
     if( interval_Pdd){
      console.log("销毁定时器：------")
        observer.disconnect();
        clearInterval(interval_Pdd)
     }
  }
})
